model Deposit {
  id          Int       @id @default(autoincrement())
  userId      Int
  trashType   TrashType
  grammage    Float
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
}

enum TrashType {
  PLASTIC
  PAPER
  GLASS
  METAL
}
